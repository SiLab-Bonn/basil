#TDL input
set_property PACKAGE_PIN AB22 [get_ports sig_in]
set_property IOSTANDARD LVCMOS33 [get_ports sig_in]
set_property PACKAGE_PIN AD23 [get_ports trig_in]
set_property IOSTANDARD LVCMOS33 [get_ports trig_in]


# Pushing the delay lines into one clock region
create_pblock pblock_sampler_rising
add_cells_to_pblock [get_pblocks pblock_sampler_rising] [get_cells -quiet [list i_bdaq53_eth_tdl_core/i_tdc/rising_tdl/sampler]]
resize_pblock [get_pblocks pblock_sampler_rising] -add {SLICE_X12Y1:SLICE_X19Y52}
set_property LOC SLICE_X15Y12 [get_cells {i_bdaq53_eth_tdl_core/i_tdc/rising_tdl/sampler/FirstCell/CARRY4_inst}]
create_pblock pblock_sampler_falling
add_cells_to_pblock [get_pblocks pblock_sampler_falling] [get_cells -quiet [list i_bdaq53_eth_tdl_core/i_tdc/falling_tdl/sampler]]
resize_pblock [get_pblocks pblock_sampler_falling] -add {SLICE_X28Y1:SLICE_X35Y52}
set_property LOC SLICE_X31Y12 [get_cells {i_bdaq53_eth_tdl_core/i_tdc/falling_tdl/sampler/FirstCell/CARRY4_inst}]

